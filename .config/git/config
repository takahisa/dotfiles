[user]
  useConfigOnly = true

[init]
  defaultBranch = main

[core]
  excludesFile = "~/.config/git/ignore.private"

[pull]
  ff = only
  rebase = true

[push]
  default = upstream
  autoSetupRemote = true

[branch]
  autoSetupRebase = always

[merge]
  ff = false

[alias]
	cc = "!git push -u origin $(git rev-parse --abbrev-ref HEAD)"
	
  co = checkout
	cb = checkout -b
	
  cp = cherry-pick
	
  br = branch
	ba = branch -a
	
  up = pull --rebase

	now = "!git commit -m \"$(date '+%Y/%m/%d %H:%M:%S')\""
  
  amend = commit --amend
  fixup = commit --fixup
  
  cancel = "!git restore --staged $(git diff --name-only --cached)"

[include]
  path = ~/.config/git/config.private
